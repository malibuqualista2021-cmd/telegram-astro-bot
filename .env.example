# Telegram BotFather'dan alınan token (zorunlu)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# --- LLM: aşağıdakilerden EN AZ BİRİ (OpenAI şart değil) ---
# Ücretsiz öneri: Groq — https://console.groq.com/keys
GROQ_API_KEY=

# Veya OpenAI: https://platform.openai.com/api-keys
# OPENAI_API_KEY=

# Veya Google Gemini: https://aistudio.google.com/apikey
# GEMINI_API_KEY=
# (alternatif isim) GOOGLE_API_KEY=

# İsteğe bağlı: openai | groq | gemini — yazmazsan hangi anahtar doluysa o seçilir
# LLM_PROVIDER=groq

# İsteğe bağlı model (sağlayıcıya göre değişir; boş bırakırsan kod varsayılanını kullanır)
# LLM_MODEL=llama-3.3-70b-versatile

# Uzun soru / sinastri / harita modunda kullanılacak ikinci model (boşsa hep LLM_MODEL)
# LLM_MODEL_DEEP=llama-3.3-70b-versatile

# Bilgi klasörü RAG eşiği (50–92)
# KNOWLEDGE_RAG_MIN_SCORE=62

# İki aşamalı yanıt: önce kısa iç plan, sonra asıl cevap (ek LLM çağrısı = daha yüksek maliyet)
# CHAIN_LLM=1

# Kalıcı kullanıcı verisi: yerel için SQLite (data/), Railway için PostgreSQL önerilir
# DATA_DIR=./data
# DATABASE_URL=postgresql://...
# 👍/👎 geri bildirimleri: data/analytics.db (ayar gerekmez; klasör data/ altında oluşur)

# İsteğe bağlı hata izleme
# SENTRY_DSN=https://...
# ENV=production

# Tek mesajda LLM'e gidecek en fazla karakter
# MAX_USER_MESSAGE_CHARS=4000

# İnce ayar
# LOG_LEVEL=INFO
# OPENAI_MAX_TOKENS=600
# OPENAI_TEMPERATURE=0.35
# FAQ_FUZZY_THRESHOLD=82
# RATE_LIMIT_PER_MINUTE=35
# CONVERSATION_MAX_TURNS=4
