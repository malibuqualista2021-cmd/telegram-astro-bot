# Telegram BotFather'dan alınan token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# OpenAI API anahtarı (https://platform.openai.com/api-keys)
OPENAI_API_KEY=your_openai_api_key_here

# İsteğe bağlı
# OPENAI_MODEL=gpt-4o-mini

# İnce ayar (satırı silersen kod içi varsayılanlar kullanılır)
# LOG_LEVEL=INFO
# OPENAI_MAX_TOKENS=600
# OPENAI_TEMPERATURE=0.35
# FAQ_FUZZY_THRESHOLD=82
# RATE_LIMIT_PER_MINUTE=35
# CONVERSATION_MAX_TURNS=4
